{
  "manifest_version": 3,
  "name": "Recipe Mod Detector — Hebrew",
  "version": "2.0",
  "description": "Automatically detects recipe modifications in Hebrew YouTube comments.",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://danielddds-hebrew-recipe-mod-api.hf.space/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://m.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}