# =============================================================================
# Git Ignore - Recipe Modification Extraction (Full Version)
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
*.env
.cache/

# -----------------------------------------------------------------------------
# Data (Surgical Rules for recipe_project structure)
# -----------------------------------------------------------------------------
# 1. Ignore EVERYTHING in the data folder by default
recipe_project/data/**/*

# 2. Re-allow .gitkeep files to maintain the folder structure
!recipe_project/data/**/.gitkeep

# 3. WHITELIST: Small files the LLM needs to see (Gold, Metadata, Samples)
!recipe_project/data/gold_validation/Gold_lables.jsonl
!recipe_project/data/processed/*.json
!recipe_project/data/processed/val.jsonl
!recipe_project/data/processed/test.jsonl
!recipe_project/data/silver_labels/*.json
!recipe_project/data/silver_labels/*.jsonl

# 4. BLACKLIST: Heavy files that will break Git/HuggingFace (Over 100MB)
recipe_project/data/processed/train_merged.jsonl
recipe_project/data/processed/train.jsonl
recipe_project/data/silver_labels/teacher_output.jsonl
recipe_project/data/raw_youtube/*

# -----------------------------------------------------------------------------
# Models & Logs (Too large or transient)
# -----------------------------------------------------------------------------
models/
logs/
*.log
tensorboard/
results/
*.pth
*.bin

# -----------------------------------------------------------------------------
# Python & Jupyter
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.ipynb_checkpoints/
*.ipynb_checkpoints

# Virtual environments
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# IDE & OS
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.bak
*.tmp
*.temp